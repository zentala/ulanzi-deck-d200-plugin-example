#!/usr/bin/env sh
# Fast checks on every commit: lint + format + typecheck inside the plugin folder.
# Heavy checks (tests) live in pre-push.
set -e

PLUGIN_DIR="ulanzi-demos/plugins/demo/io.zentala.ulanzideck.demo.ulanziPlugin"

# Skip when no JS/HTML/JSON staged inside the plugin folder — keeps doc-only commits fast.
if ! git diff --cached --name-only | grep -qE "^${PLUGIN_DIR}/.*\.(js|mjs|cjs|html|json)$"; then
  exit 0
fi

cd "$PLUGIN_DIR"
echo "→ lint"
pnpm lint
echo "→ format check"
pnpm format:check
echo "→ typecheck"
pnpm typecheck

# If any action source changed, regenerate previews so README stays accurate.
# Auto-stages the regenerated PNGs — single source of truth, no manual step.
ACTION_CHANGED=$(git diff --cached --name-only --relative | grep -E "^plugin/actions/.*Action\.js$" || true)
if [ -n "$ACTION_CHANGED" ]; then
  echo "→ action changed — regenerating assets/previews/*.png"
  pnpm previews
  git add assets/previews/
fi
