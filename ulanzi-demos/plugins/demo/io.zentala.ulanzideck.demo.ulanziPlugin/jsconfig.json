{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": []
  },
  "include": ["plugin/**/*.js", "plugin/types.d.ts"],
  "exclude": ["plugin/libs/**", "node_modules/**", "libs/**"]
}
