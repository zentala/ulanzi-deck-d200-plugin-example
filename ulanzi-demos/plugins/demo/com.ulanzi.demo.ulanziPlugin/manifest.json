{
  "Name": "Ulanzi Demo",
  "Author": "ulanzi-demos",
  "Version": "1.0.0",
  "Description": "Demo plugin: clock, counter, CPU status",
  "Icon": "assets/icons/icon.png",
  "Category": "Ulanzi Demo",
  "CategoryIcon": "assets/icons/categoryIcon.png",
  "UUID": "com.ulanzi.demo",
  "Type": "JavaScript",
  "CodePath": "plugin/app.html",
  "PrivateAPI": true,
  "SupportedInMultiActions": false,
  "Software": {
    "MinimumVersion": "6.1"
  },
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" },
    { "Platform": "mac", "MinimumVersion": "10.11" }
  ],
  "Actions": [
    {
      "Name": "Clock",
      "UUID": "com.ulanzi.demo.clock",
      "Tooltip": "Digital clock updated every second",
      "Icon": "assets/icons/actionIcon.png",
      "PropertyInspectorPath": "property-inspector/clock/inspector.html",
      "SupportedInMultiActions": false,
      "state": 0,
      "States": [
        { "Name": "clock", "Image": "assets/icons/actionIcon.png" }
      ]
    },
    {
      "Name": "Counter",
      "UUID": "com.ulanzi.demo.counter",
      "Tooltip": "Tap to increment. Hold to reset.",
      "Icon": "assets/icons/actionIcon.png",
      "PropertyInspectorPath": "property-inspector/counter/inspector.html",
      "SupportedInMultiActions": false,
      "state": 0,
      "States": [
        { "Name": "counter", "Image": "assets/icons/actionIcon.png" }
      ]
    },
    {
      "Name": "CPU Status",
      "UUID": "com.ulanzi.demo.status",
      "Tooltip": "CPU usage monitor with alert",
      "Icon": "assets/icons/actionIcon.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "SupportedInMultiActions": false,
      "state": 0,
      "States": [
        { "Name": "status", "Image": "assets/icons/actionIcon.png" }
      ]
    },
    {
      "Name": "Calendar",
      "Tooltip": "Today's date in calendar style",
      "UUID": "com.ulanzi.ulanzideck.demo.calendar",
      "Icon": "assets/plugin-icon",
      "PropertyInspectorPath": "property-inspector/calendar/inspector.html",
      "States": [
        { "Image": "assets/plugin-icon", "TitleAlignment": "middle", "FontSize": "14" }
      ]
    },
    {
      "Name": "Pomodoro",
      "Tooltip": "Pomodoro work/break timer",
      "UUID": "com.ulanzi.ulanzideck.demo.pomodoro",
      "Icon": "assets/plugin-icon",
      "PropertyInspectorPath": "property-inspector/pomodoro/inspector.html",
      "States": [
        { "Image": "assets/plugin-icon", "TitleAlignment": "middle", "FontSize": "14" }
      ]
    }
  ]
}
