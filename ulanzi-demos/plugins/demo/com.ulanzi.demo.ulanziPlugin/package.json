{
  "name": "com.ulanzi.demo-plugin-tests",
  "private": true,
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/ --forceExit",
    "lint": "eslint plugin/ tests/",
    "lint:fix": "eslint plugin/ tests/ --fix",
    "format": "prettier --write plugin/ tests/",
    "format:check": "prettier --check plugin/ tests/",
    "typecheck": "echo 'typecheck: skipped (plain JS with runtime globals)'",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "canvas": "^2.11.0",
    "eslint": "^9",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
